{
    "component_id": "cits_v2x_emulation",
    "scenario_id": "porto_boavista_base_v04_cits_v2x",
    "description": "C-ITS/V2X emulation for public transport traffic-signal priority requests in the Porto/Boavista corridor.",
    "protocol_profile": {
        "profile_name": "C-ITS TLC emulado",
        "version": "0.4.0",
        "encoding": "json",
        "messages": [
            "MAPEM",
            "SPATEM",
            "SREM",
            "SSEM"
        ],
        "note": "Os modelos JSON seguem o shape ETSI MAPEM/SPATEM/SREM/SSEM para valida\u00e7\u00e3o funcional em SUMO; n\u00e3o substituem codifica\u00e7\u00e3o ASN.1/OER/UPER, PKI ou transporte operacional real."
    },
    "sumo": {
        "sumocfg": "sumo/corredor.sumocfg",
        "network": "sumo/network/corredor.net.xml",
        "step_length_s": 1.0,
        "default_sumo_binary": "sumo",
        "default_gui_binary": "sumo-gui"
    },
    "network_discovery": {
        "enabled": true,
        "augment_missing_intersections": true,
        "auto_generate_priority_movements": true,
        "priority_vehicle_classes": [
            "public_transport"
        ],
        "rsu_id_prefix": "RSU_AUTO_"
    },
    "logging": {
        "message_log": "outputs/cits_messages.jsonl",
        "summary_report": "reports/cits_emulation_summary.json",
        "mapem_snapshot": "outputs/cits_mapem_snapshot.json",
        "spatem_snapshot": "outputs/cits_spatem_snapshot.json"
    },
    "synthetic_geometry": {
        "enabled": true,
        "origin_latitude_e7": 410000000,
        "origin_longitude_e7": -86000000,
        "intersection_spacing_e7": 7500,
        "lateral_offset_e7": 200,
        "elevation_dm": 0,
        "assumption": "Synthetic WGS84-like anchor points for SUMO-only MAPEM geometry; not surveyed operational coordinates."
    },
    "message_transport": {
        "enabled": false,
        "encode_payloads": false,
        "latency_steps": 0,
        "jitter_steps": 0,
        "drop_rate": 0.0,
        "duplicate_rate": 0.0,
        "reorder_window_steps": 0,
        "random_seed": 57
    },
    "trust_store": {
        "mode": "prefix_allowlist",
        "allowed_signer_prefixes": [
            "OBU_bus_",
            "OBU_ev_",
            "OBU_emergency_",
            "RSU_BOAVISTA_"
        ],
        "revoked_certificate_ids": [],
        "assumption": "Simulated trust policy for SUMO. This is not ETSI PKI validation."
    },
    "obu_policy": {
        "request_distance_m": 250,
        "request_eta_min_s": 8,
        "request_eta_max_s": 45,
        "emergency_request_eta_max_s": 90,
        "delay_threshold_s": 20,
        "headway_deviation_threshold_s": 120,
    "request_refresh_s": 5,
    "request_ttl_s": 12,
    "allow_nominal_priority_requests": false,
    "suppress_requests_at_stop": true,
    "priority_line_ids": [
            "STCP500_PROXY_E",
            "STCP500_PROXY_W",
            "STCP502_PROXY_E",
            "STCP502_PROXY_W"
        ],
        "bus_id_prefixes": [
            "bus_"
        ],
        "emergency_id_prefixes": [
            "ev_",
            "emergency_"
        ]
    },
    "rsu_policy": {
        "response_ttl_s": 15,
        "dedupe_cache_ttl_s": 30,
        "cooldown_after_grant_s": 90,
        "max_active_requests_per_rsu": 4,
        "acceptance_mode": "processing_for_decision_engine",
        "default_reject_reason": "not_eligible_for_priority"
    },
    "schedule_plan": {
        "_comment": "Stand-in determinístico de aderência a horário (AVL/APC). Desligado por defeito; ligar desloca KPIs. Ver pps57_cits.schedule_plan.",
        "enabled": false,
        "random_seed": 57,
        "timetable_source": "configs/sumo_scenario_base.json",
        "schedule_delay_scale_s": 90.0,
        "headway_deviation_fraction": 0.25
    },
    "state_estimation": {
        "_comment": "Constantes de estimação de estado (ETA/spillback) e fila real. Defaults reproduzem os literais anteriores; real_back_of_queue é opt-in. queue_halt_speed_mps deve ficar <= ao --halting-speed-threshold do SUMO (0.1) para a fila ser subconjunto de halted. Ver pps57_cits.traci_adapter / models.EtaParams.",
        "eta_free_flow_speed_mps": 8.0,
        "eta_queue_penalty_s": 2.0,
        "eta_waiting_cap_s": 15.0,
        "eta_min_speed_mps": 0.5,
        "spillback_occupancy_threshold": 0.75,
        "spillback_halted_per_lane": 4,
        "real_back_of_queue": false,
        "queue_halt_speed_mps": 0.1
    },
    "safety_constraints": {
        "min_green_s": 8,
        "max_green_extension_s": 12,
        "max_total_green_s": 55,
        "yellow_s": 3,
        "all_red_s": 1,
        "pedestrian_clearance_must_not_be_shortened": true,
        "never_skip_yellow_or_all_red": true,
        "max_consecutive_priority_interventions_per_tls": 2,
        "cooldown_after_priority_s": 90,
        "max_recovery_debt_s": 24,
        "recovery_debt_payback_rate_s_per_s": 1
    },
    "priority_hierarchy": {
        "_comment": "Chaves alinhadas com OperatorPriorityClass (extensão operador, não-standard ETSI). Ranking é usado pelo TSP para ordenar pedidos simultâneos no mesmo tick.",
        "emergency": 1,
        "high_delay": 2,
        "headway_recovery": 3,
        "nominal": 4
    },
