{
  "component_id": "transit_signal_priority_policy_optimization",
  "version": "1.0.0",
  "scenario_id": "porto_boavista_base_v04_policy_training",
  "description": "Offline policy optimization and tabular reinforcement-learning training for explainable transit signal priority with a mandatory safety filter.",
  "logging": {
    "sample_log": "outputs/offline_policy_samples.jsonl",
    "candidate_log": "outputs/policy_candidates.jsonl",
    "policy_report": "reports/policy_report.json",
    "summary_report": "reports/policy_optimization_summary.json",
    "q_table_report": "reports/tabular_q_policy_report.json",
    "rl_training_summary": "reports/rl_training_summary.json",
    "event_training_dataset": "outputs/event_training_dataset.jsonl"
  },
  "offline_training": {
    "episodes": 1,
    "candidate_actions": [
      "no_action",
      "green_extension",
      "early_green",
      "reevaluate_next_cycle",
      "reject"
    ],
    "state_buckets": {
      "eta_close_s": 10,
      "eta_far_s": 25,
      "medium_delay_s": 60,
      "high_delay_s": 90,
      "phase_switch_close_s": 5,
      "high_active_requests": 2,
      "high_queue_vehicle_count": 8,
      "high_halted_vehicle_count": 8,
      "low_mean_speed_mps": 2.0,
      "high_waiting_time_s": 120,
      "high_occupancy": 0.6,
      "cooldown_recent_s": 90
    }
  },
  "reward": {
    "bus_delay_weight": 1.0,
    "headway_weight": 0.25,
    "proximity_weight": 0.3,
    "general_traffic_penalty_per_second": 0.35,
    "traffic_pressure_penalty_multiplier": 8.0,
    "reevaluate_penalty": 8.0,
    "reject_penalty": 20.0,
    "unsafe_candidate_penalty": 1000.0
  },
  "reinforcement_learning": {
    "algorithm": "tabular_q_learning",
    "episodes": 200,
    "alpha": 0.25,
    "gamma": 0.0,
    "epsilon_start": 0.35,
    "epsilon_min": 0.02,
    "epsilon_decay": 0.985,
    "seed": 57
  },
  "safety": {
    "mandatory_filter": true,
    "allow_unsafe_policy_export": false
  }
}
