{
  "scenario_id": "porto_boavista_realista_v02_pacote3_cits",
  "description": "Emulação C-ITS/V2X para pedidos de prioridade semafórica de transporte público no corredor Porto/Boavista.",
  "protocol_profile": {
    "profile_name": "C-ITS TLC emulado",
    "version": "0.3.0",
    "encoding": "json",
    "messages": ["MAPEM_like", "SPATEM_like", "SREM_like", "SSEM_like"],
    "note": "Os modelos são SREM/SSEM/MAPEM/SPATEM-like para validação funcional; não substituem codificação ASN.1/UPER ETSI em operação real."
  },
  "sumo": {
    "sumocfg": "sumo/corredor.sumocfg",
    "network": "sumo/network/corredor.net.xml",
    "step_length_s": 1.0,
    "default_sumo_binary": "sumo",
    "default_gui_binary": "sumo-gui"
  },
  "logging": {
    "message_log": "outputs/cits_messages.jsonl",
    "summary_report": "reports/cits_emulation_summary.json",
    "mapem_snapshot": "outputs/cits_mapem_snapshot.json",
    "spatem_snapshot": "outputs/cits_spatem_snapshot.json"
  },
  "obu_policy": {
    "request_distance_m": 250,
    "request_eta_min_s": 8,
    "request_eta_max_s": 45,
    "delay_threshold_s": 60,
    "headway_deviation_threshold_s": 120,
    "request_refresh_s": 5,
    "request_ttl_s": 12,
    "demo_force_bus_delay_s": 90,
    "priority_line_ids": ["STCP500_PROXY_E", "STCP500_PROXY_W", "STCP502_PROXY_E", "STCP502_PROXY_W"],
    "bus_id_prefixes": ["bus_"],
    "requested_maneuvers": ["green_extension", "early_green", "priority_candidate"]
  },
  "rsu_policy": {
    "response_ttl_s": 15,
    "cooldown_after_grant_s": 90,
    "max_active_requests_per_rsu": 4,
    "acceptance_mode": "acknowledge_for_decision_engine",
    "default_reject_reason": "not_eligible_for_priority"
  },
  "safety_constraints": {
    "min_green_s": 8,
    "max_green_extension_s": 12,
    "max_total_green_s": 55,
    "yellow_s": 3,
    "all_red_s": 1,
    "pedestrian_clearance_must_not_be_shortened": true,
    "never_skip_yellow_or_all_red": true,
    "max_consecutive_priority_interventions_per_tls": 2,
    "cooldown_after_priority_s": 90
  },
  "priority_hierarchy": {
    "emergency_vehicle": 1,
    "public_transport_high_delay": 2,
    "public_transport_headway_recovery": 3,
    "public_transport_nominal": 4,
    "general_traffic": 5
  },
