{
  "component_id": "tsp_safety_layer",
  "version": "0.4.0",
  "scenario_id": "porto_boavista_base_v04_tsp_safety_layer",
  "description": "Motor de decisão TSP e Safety Layer para prioridade semafórica contextual em movimentos prioritários configurados.",
  "logging": {
    "decision_log": "outputs/tsp_decisions.jsonl",
    "actuation_log": "outputs/tsp_actuation.jsonl",
    "summary_report": "reports/tsp_emulation_summary.json"
  },
  "decision_policy": {
    "min_priority_score": 0.2,
    "delay_normalisation_s": 180,
    "headway_normalisation_s": 240,
    "distance_normalisation_m": 250,
    "eta_arrival_buffer_s": 4,
    "green_extension_min_s": 3,
    "green_extension_default_s": 8,
    "green_extension_max_s": 12,
    "early_green_min_eta_s": 10,
    "red_truncation_to_s": 2,
    "recovery_note": "After a TSP intervention, the controller returns to the base SUMO signal program; coordinated offsets remain a calibration task.",
    "priority_level_weights": {
      "emergency": 1.0,
      "high_delay": 0.85,
      "headway_recovery": 0.7,
      "nominal": 0.45
    },
    "actuating_actions": ["green_extension", "early_green"],
    "weights": {
      "schedule_delay": 0.45,
      "headway_deviation": 0.2,
      "proximity": 0.2,
      "priority_level": 0.15
    }
  },
  "actuation": {
    "allow_green_extension": true,
    "allow_red_truncation": true,
    "allow_direct_phase_jump": false,
    "note": "No MVP, early_green é implementado como redução segura da duração da fase corrente via setPhaseDuration, não como salto direto de fase. Isto evita saltar amarelo/all-red."
  },
  "corridor": {
    "_comment": "Árbitro de corredor cross-TLS (P6), opt-in, corre pré-Safety e só DESCE decisões (a Safety Layer continua o portão final). Todas as features desligadas por defeito = no-op. É otimização, NÃO segurança — distinto dos safety_constraints fail-closed em cits_v2x_config.json. max_corridor_recovery_debt_s: null ou <= 0 = cap desligado (0 permite a primeira intervenção).",
    "max_corridor_recovery_debt_s": null,
    "respect_downstream_spillback": false,
    "flag_green_wave": false
  },
  "network_profile": {
    "enabled": true,
    "prefer_generated_contracts_for_unknown_tls": true,
    "description": "Quando um novo net.xml e importado sem contrato especifico, gera phase_sequence, grupos e conflitos a partir do programa SUMO."
  },
