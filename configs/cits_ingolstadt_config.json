{
    "component_id": "cits_v2x_emulation",
    "scenario_id": "ingolstadt_citywide",
    "description": "C-ITS/V2X emulation for TSP on the real calibrated Ingolstadt network (TUM-VT scenario, GTFS public transport). All 123 TLS via network auto-discovery; trust store accepts the scenario's bus OBU signers and auto-generated RSUs.",
    "protocol_profile": {
        "profile_name": "C-ITS TLC emulado",
        "version": "0.4.0",
        "encoding": "json",
        "messages": ["MAPEM", "SPATEM", "SREM", "SSEM"],
        "note": "JSON segue o shape ETSI para validação funcional em SUMO; não substitui ASN.1/OER, PKI ou transporte real."
    },
    "sumo": {
        "sumocfg": ".tools/ingol_run/demo.sumocfg",
        "network": ".tools/ingol_run/ingolstadt_net.net.xml",
        "step_length_s": 1.0,
        "default_sumo_binary": "sumo",
        "default_gui_binary": "sumo-gui",
        "_comment": "Os paths apontam para o cenário materializado por scripts/run_ingolstadt_demo.py (.tools/ é git-ignored); o runner sobrepõe-nos com o caminho/janela escolhidos."
    },
    "network_discovery": {
        "enabled": true,
        "augment_missing_intersections": true,
        "auto_generate_priority_movements": true,
        "priority_vehicle_classes": ["public_transport"],
        "rsu_id_prefix": "RSU_AUTO_"
    },
    "logging": {
        "message_log": "outputs/ingolstadt/cits_messages.jsonl",
        "summary_report": "reports/ingolstadt/cits_emulation_summary.json",
        "mapem_snapshot": "outputs/ingolstadt/cits_mapem_snapshot.json",
        "spatem_snapshot": "outputs/ingolstadt/cits_spatem_snapshot.json"
    },
    "synthetic_geometry": {
        "enabled": true,
        "origin_latitude_e7": 487600000,
        "origin_longitude_e7": 114200000,
        "intersection_spacing_e7": 7500,
        "lateral_offset_e7": 200,
        "elevation_dm": 0,
        "assumption": "Âncoras WGS84-like sintéticas para a geometria MAPEM apenas-SUMO; não são coordenadas operacionais levantadas."
    },
    "message_transport": {
        "enabled": false,
        "encode_payloads": false,
        "latency_steps": 0,
        "jitter_steps": 0,
        "drop_rate": 0.0,
        "duplicate_rate": 0.0,
        "reorder_window_steps": 0,
        "random_seed": 57
    },
    "trust_store": {
        "mode": "prefix_allowlist",
        "allowed_signer_prefixes": ["OBU_Bus", "OBU_bus_", "RSU_AUTO_"],
        "revoked_certificate_ids": [],
        "emergency_authorization": {
            "authorized_signer_ids": [],
            "authorized_certificate_ids": [],
            "assumption": "O GTFS de Ingolstadt não traz veículos de emergência; nenhuma identidade de preempção autorizada. A classe emergency continua a exigir enumeração explícita (não basta um prefixo)."
        },
        "assumption": "Política de confiança simulada para SUMO. Os autocarros do cenário assinam OBU_Bus___...; os RSUs são auto-gerados com prefixo RSU_AUTO_. Não é validação ETSI PKI."
    },
    "obu_policy": {
        "request_distance_m": 250,
        "request_eta_min_s": 8,
        "request_eta_max_s": 45,
        "emergency_request_eta_max_s": 90,
        "delay_threshold_s": 20,
        "headway_deviation_threshold_s": 120,
        "request_refresh_s": 5,
        "request_ttl_s": 12,
        "allow_nominal_priority_requests": false,
        "suppress_requests_at_stop": true,
        "priority_line_ids": [],
        "bus_id_prefixes": ["Bus", "bus_"],
        "emergency_id_prefixes": ["ev_", "emergency_"]
    },
    "rsu_policy": {
        "response_ttl_s": 15,
        "dedupe_cache_ttl_s": 30,
        "cooldown_after_grant_s": 90,
        "max_active_requests_per_rsu": 4,
        "acceptance_mode": "processing_for_decision_engine",
        "default_reject_reason": "not_eligible_for_priority"
    },
    "schedule_plan": {
        "_comment": "Aderência a horário a partir do GTFS REAL do cenário (tempos `until` por paragem): schedule_delay = sim_time - hora agendada da próxima paragem. Não fabrica dados. O runner sobrepõe os paths com o cenário materializado.",
        "enabled": true,
        "mode": "gtfs",
        "gtfs_trips": ".tools/ingol_run/PT/2023-07-04_gtfs_trips.rou.xml",
        "pt_stops": ".tools/ingol_run/PT/pt_stops.add.xml"
    },
    "state_estimation": {
        "eta_free_flow_speed_mps": 8.0,
        "eta_queue_penalty_s": 2.0,
        "eta_waiting_cap_s": 15.0,
        "eta_min_speed_mps": 0.5,
        "spillback_occupancy_threshold": 0.75,
        "spillback_halted_per_lane": 4,
        "real_back_of_queue": false,
        "queue_halt_speed_mps": 0.1
    },
    "safety_constraints": {
        "min_green_s": 8,
        "max_green_extension_s": 12,
        "max_total_green_s": 90,
        "yellow_s": 3,
        "all_red_s": 1,
        "pedestrian_clearance_must_not_be_shortened": true,
        "never_skip_yellow_or_all_red": true,
        "max_consecutive_priority_interventions_per_tls": 2,
        "cooldown_after_priority_s": 90,
        "max_recovery_debt_s": 24,
        "recovery_debt_payback_rate_s_per_s": 1
    },
    "priority_hierarchy": {
        "emergency": 1,
        "high_delay": 2,
        "headway_recovery": 3,
        "nominal": 4
    },
    "intersections": []
}
