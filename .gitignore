# Local Python environment
.venv/

# Python caches and packaging
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg-info/

# Local environment files
.env
.env.*

# macOS/editor files
.DS_Store
.idea/
.vscode/

# Generated SUMO/pipeline outputs.
# Padrões recursivos (**/): cobrem também subdiretórios de snapshot como
# outputs/runs/baseline/ e outputs/runs/rl/ produzidos por compare-tsp-rl.
outputs/**/*.xml
outputs/**/*.csv
outputs/**/*.json
outputs/**/*.jsonl
outputs/**/*.log
reports/**/*.json
sumo/network/*.net.xml

# Editor / tooling metadata (downloads helpers, gh cache, etc.)
.tools/
.claude/

# Source patch artifacts already applied to the repository.
*.patch
*.patch.bak
